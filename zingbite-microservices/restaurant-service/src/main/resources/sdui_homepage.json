      "props": { 
        "title": "Hungry? Grab a ZingBite!", 
        "subtitle": "Delivering fresh meals to your doorstep within minutes." 
      } 
    },
    {
      "id": "weather_surge_banner",
      "visible": true,
      "order": 2,
      "props": {
        "title": "Weather Alert",
        "subtitle": "Raining heavily outside. Weather surge helps support our delivery partners."
      }
    },
    {
      "id": "group_order_cta",
      "visible": true,
      "order": 3,
      "props": {
        "title": "Planning a Group Meal?",
