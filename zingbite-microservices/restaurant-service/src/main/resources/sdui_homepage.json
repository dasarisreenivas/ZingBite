      "order": 13,
      "props": {
        "title": "Spotlight Review Feed",
        "reviews": [
          { "id": 1, "username": "Rajesh K.", "rating": 5, "comment": "The Biryani combo was absolutely flavorful and delivered super hot!", "restaurantName": "Grand Biryani Palace" },
