    {
      "id": "featured_restaurants",
      "visible": true,
      "order": 10,
      "props": {
        "title": "Top Curated Picks",
        "subtitle": "Highest-rated culinary spots in your area",
        "minRating": 4.5
      }
    },
    {
      "id": "neighborhood_trends",
      "visible": true,
      "order": 11,
      "props": {
        "title": "Trending Near You",
        "radiusKm": 5
      }
    },
    { 
      "id": "restaurant_grid", 
      "visible": true, 
      "order": 12, 
      "props": { 
        "pageSize": 8, 
        "showFilters": true 
      } 
    },
    {
